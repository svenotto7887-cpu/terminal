# Production Environment Variables
# Copy this to your cloud platform's environment settings
# Replace all VALUES with your actual production values

# === BACKEND CONFIGURATION ===

# Server Port (DO NOT CHANGE - cloud platform manages this)
PORT=4000

# Database Connection (from cloud provider - RDS, Railway, Heroku Postgres, etc.)
DATABASE_URL=postgresql://user:password@hostname:5432/terminal

# Redis Cache (from cloud provider - ElastiCache, Railway, Heroku Redis, etc.)
REDIS_URL=redis://:password@hostname:6379

# JWT Secret for Token Signing (GENERATE: openssl rand -hex 32)
JWT_SECRET=your-random-32-character-secret-key-here

# CORS Origin (MUST match your frontend URL exactly, no trailing slash)
# For Render: https://terminal-frontend-xxxxx.onrender.com
# For Railway: https://terminal-frontend.up.railway.app
# For Heroku: https://terminal-frontend-xxxxx.herokuapp.com
FRONTEND_ORIGIN=https://your-frontend-url.com

# API Keys (optional - for enhanced market data)
FINNHUB_API_KEY=your-finnhub-api-key
POLYGON_API_KEY=your-polygon-api-key

# Node Environment
NODE_ENV=production

# Log Level
LOG_LEVEL=info

# === SEI BLOCKCHAIN CONFIGURATION ===

# SEI RPC Endpoints
SEI_RPC_MAINNET=https://evm-rpc.sei-apis.com
SEI_RPC_TESTNET=https://evm-testnet-rpc.sei-apis.com
SEI_WS_MAINNET=wss://evm-ws.sei-apis.com
SEI_WS_TESTNET=wss://evm-testnet-ws.sei-apis.com

# Network Selection (mainnet or testnet)
SEI_NETWORK=mainnet

# === FRONTEND CONFIGURATION (for CI/CD) ===

# This is set by frontend/.env.production
# But also available as build arg in Docker
VITE_API_BASE_URL=https://your-backend-url.com/api
VITE_WS_URL=wss://your-backend-url.com

# === PLATFORM-SPECIFIC VARIABLES ===

# Render.com specific (optional)
# RENDER_EXTERNAL_URL is auto-set by Render

# Railway specific (optional)
# Railway auto-injects from linked services

# Heroku specific (optional)
# DATABASE_URL is auto-generated for Postgres add-on
# REDIS_URL is auto-generated for Redis add-on

# === MONITORING & ERROR TRACKING (optional) ===

# Sentry (error tracking)
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# Datadog (monitoring)
# DATADOG_API_KEY=your-datadog-key

# === SECRETS (DO NOT COMMIT THIS FILE) ===
# This file is for REFERENCE ONLY
# Never commit actual secret values to GitHub
# Always set secrets in cloud platform dashboard

# Render.com secrets → Settings → Environment
# Railway secrets → Variables → Add Variable
# Heroku secrets → Settings → Config Vars
# AWS → Secrets Manager
# DigitalOcean → App Spec environment

