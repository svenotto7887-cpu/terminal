# -------- Front‑end --------
VITE_API_BASE_URL=http://localhost:4000/api
VITE_WS_URL=http://localhost:4000
VITE_PORT=3000

# Sei Blockchain Configuration
VITE_SEI_NETWORK=testnet  # mainnet or testnet (atlantic-2)
VITE_SEI_RPC_URL=https://evm-rpc-testnet.sei-apis.com
VITE_SEI_WS_URL=wss://evm-ws-testnet.sei-apis.com

# WalletConnect (Optional, for RainbowKit integration)
VITE_WALLETCONNECT_PROJECT_ID=

# Feature Flags
VITE_ENABLE_SEI_TRADING=true
VITE_ENABLE_REAL_TIME_UPDATES=true
