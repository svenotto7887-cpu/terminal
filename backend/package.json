{
  "name": "terminal-backend",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist && rimraf node_modules"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.6.0",
    "express": "^4.22.1",
    "helmet": "^8.0.0",
    "pg": "^8.19.0",
    "redis": "^4.7.1",
    "socket.io": "^4.5.1",
    "uuid": "^9.0.1",
    "ws": "^8.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.35",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.1",
    "rimraf": "^5.0.10",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^0.34.6"
  }
}
