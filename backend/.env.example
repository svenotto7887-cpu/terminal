# -------- Back‑end --------
PORT=4000
DATABASE_URL=postgresql://user:password@localhost:5432/terminal_db
REDIS_URL=redis://localhost:6379
FRONTEND_ORIGIN=http://localhost:3000

# Sei Blockchain (EVM)
SEI_NETWORK=testnet  # mainnet, testnet (atlantic-2), or devnet (arctic-1)
SEI_RPC_URL=https://evm-rpc-testnet.sei-apis.com
SEI_WS_URL=wss://evm-ws-testnet.sei-apis.com
SEI_CHAIN_ID=1328  # 1329=mainnet, 1328=testnet, 713715=devnet

# Optional: Sei smart contracts
SEI_CONTRACT_ADDRESS=0x
SEI_ORDER_BOOK_ADDRESS=0x
SEI_TOKEN_ADDRESS=0x

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY=24h

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug

# Market Data
PRICE_FEED_INTERVAL=5000
ORDERBOOK_DEPTH=20

# WebSocket
WS_PORT=3001
WS_PATH=/socket.io
